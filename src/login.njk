---
layout: layout.njk
permalink: /login/index.html
eleventyExcludeFromCollections: true
---

<article>
  <h2>Este blog es privado</h2>
  <form id="login-form">
    <p>
      <label for="password">Contrasenia:</label><br>
      <input type="password" id="password" name="password" required autofocus
        style="font-size:1rem;padding:0.5rem;width:100%;max-width:300px;margin-top:0.3rem;border:1px solid #ccc;border-radius:4px;">
    </p>
    <p id="error" style="color:#d00;display:none;"></p>
    <p>
      <button type="submit" style="font-size:1rem;padding:0.5rem 1.5rem;cursor:pointer;background:#1a1a1a;color:#fff;border:none;border-radius:4px;">
        Entrar
      </button>
    </p>
  </form>
</article>

<script>
document.getElementById("login-form").addEventListener("submit", async (e) => {
  e.preventDefault();
  const err = document.getElementById("error");
  err.style.display = "none";
  const res = await fetch("/api/login", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ password: document.getElementById("password").value }),
  });
  if (res.ok) {
    window.location.href = "/";
  } else {
    const data = await res.json();
    err.textContent = data.error;
    err.style.display = "block";
  }
});
</script>
